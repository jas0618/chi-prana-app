<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>Chi · Prana — Daily Energy App</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
 
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
 
    body {
      background: #2C2C2A;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      min-height: 100vh;
      padding: 20px 0;
    }
 
    .app {
      font-family: 'DM Sans', sans-serif;
      background: #FBF7EF;
      min-height: 100vh;
      color: #2C2C2A;
      width: 100%;
      max-width: 420px;
      position: relative;
      overflow: hidden;
      border-radius: 24px;
      box-shadow: 0 40px 80px rgba(0,0,0,0.5);
    }
 
    /* ── Top bar ── */
    .top-bar {
      background: #1a1208;
      color: #F7C75A;
      padding: 14px 20px 12px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .top-bar .day-label {
      font-family: 'Cormorant Garamond', serif;
      font-size: 13px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #EF9F27;
      font-style: italic;
    }
    .top-bar .app-name {
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #888780;
    }
    .top-bar .element-badge {
      font-size: 11px;
      background: rgba(247,199,90,0.13);
      color: #F7C75A;
      border: 0.5px solid rgba(247,199,90,0.33);
      padding: 3px 10px;
      border-radius: 20px;
    }
 
    /* ── Tab views ── */
    .tab-view { display: none; }
    .tab-view.active { display: block; }
 
    /* ── Hero ── */
    .hero {
      background: linear-gradient(160deg, #1a1208 0%, #2c1f08 60%, #3b2a10 100%);
      padding: 28px 20px 32px;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -40px; right: -40px;
      width: 200px; height: 200px;
      background: radial-gradient(circle, rgba(239,159,39,0.2) 0%, transparent 70%);
      border-radius: 50%;
    }
    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 36px;
      font-weight: 300;
      color: #FAF0D7;
      line-height: 1.1;
    }
    .hero-sub {
      font-size: 12px;
      color: #888780;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      margin-top: 6px;
    }
    .element-row {
      display: flex;
      gap: 8px;
      margin-top: 18px;
      flex-wrap: wrap;
    }
    .element-chip {
      background: rgba(255,255,255,0.05);
      border: 0.5px solid rgba(255,255,255,0.13);
      border-radius: 20px;
      padding: 6px 14px;
      font-size: 12px;
      color: #D3C9B0;
    }
    .element-chip.active {
      background: rgba(239,159,39,0.13);
      border-color: #EF9F27;
      color: #FAC775;
    }
    .compass-ring {
      position: absolute;
      bottom: -30px; right: -30px;
      width: 120px; height: 120px;
      border: 0.5px solid rgba(239,159,39,0.2);
      border-radius: 50%;
    }
    .compass-ring2 {
      position: absolute;
      bottom: -10px; right: -10px;
      width: 80px; height: 80px;
      border: 0.5px solid rgba(239,159,39,0.33);
      border-radius: 50%;
    }
 
    /* ── Teaching strips ── */
    .vastu-strip {
      background: #E6F1FB;
      border-left: 3px solid #378ADD;
      border-radius: 0 10px 10px 0;
      padding: 10px 14px;
      margin: 0 20px 8px;
      font-size: 12px;
      color: #0C447C;
      line-height: 1.5;
    }
    .feng-strip {
      background: #EAF3DE;
      border-left: 3px solid #639922;
      border-radius: 0 10px 10px 0;
      padding: 10px 14px;
      margin: 0 20px 20px;
      font-size: 12px;
      color: #27500A;
      line-height: 1.5;
    }
    .strip-label {
      font-size: 9px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      font-weight: 500;
      margin-bottom: 3px;
      opacity: 0.7;
    }
 
    /* ── Section ── */
    .section { padding: 20px 20px 0; }
    .section-label {
      font-size: 10px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: #888780;
      margin-bottom: 12px;
    }
 
    /* ── Colour cards ── */
    .color-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-bottom: 20px;
    }
    .color-card {
      border-radius: 14px;
      padding: 14px;
      position: relative;
      overflow: hidden;
      cursor: pointer;
      transition: transform 0.15s;
    }
    .color-card:hover { transform: scale(1.02); }
    .color-swatch {
      width: 36px; height: 36px;
      border-radius: 50%;
      margin-bottom: 10px;
      border: 2px solid rgba(255,255,255,0.2);
    }
    .color-name  { font-size: 14px; font-weight: 500; margin-bottom: 2px; color: inherit; }
    .color-reason { font-size: 11px; opacity: 0.7; line-height: 1.4; color: inherit; }
    .power-tag {
      position: absolute;
      top: 10px; right: 10px;
      font-size: 9px;
      letter-spacing: 1px;
      text-transform: uppercase;
      background: rgba(255,255,255,0.15);
      padding: 2px 8px;
      border-radius: 10px;
      color: inherit;
      opacity: 0.8;
    }
 
    /* ── Avoid strip ── */
    .avoid-strip {
      background: #fff8ee;
      border: 0.5px solid rgba(239,159,39,0.33);
      border-radius: 12px;
      padding: 12px 16px;
      margin: 0 20px 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .avoid-dot { width: 10px; height: 10px; border-radius: 50%; background: #E24B4A; flex-shrink: 0; }
    .avoid-text { font-size: 12px; color: #5F5E5A; line-height: 1.5; }
 
    /* ── Divider ── */
    .divider { height: 0.5px; background: #D3D1C7; margin: 0 20px 20px; }
 
    /* ── Activities ── */
    .activities-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
    .activity-item {
      background: white;
      border: 0.5px solid #D3D1C7;
      border-radius: 12px;
      padding: 12px 16px;
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }
    .activity-icon {
      width: 36px; height: 36px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
    }
    .icon-gold   { background: #FAEEDA; }
    .icon-blue   { background: #E6F1FB; }
    .icon-green  { background: #EAF3DE; }
    .icon-purple { background: #EEEDFE; }
    .activity-name { font-size: 13px; font-weight: 500; margin-bottom: 2px; }
    .activity-desc { font-size: 11px; color: #888780; line-height: 1.4; }
 
    /* ── Outfit scanner ── */
    .outfit-scanner {
      margin: 0 20px 20px;
      background: #1a1208;
      border-radius: 18px;
      padding: 20px;
      position: relative;
      overflow: hidden;
    }
    .scanner-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 300;
      color: #FAF0D7;
      margin-bottom: 4px;
    }
    .scanner-sub {
      font-size: 11px;
      color: #888780;
      margin-bottom: 16px;
      letter-spacing: 1px;
    }
    .upload-zone {
      border: 1px dashed rgba(239,159,39,0.4);
      border-radius: 12px;
      padding: 24px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      background: rgba(255,255,255,0.03);
      position: relative;
    }
    .upload-zone:hover { border-color: #EF9F27; background: rgba(239,159,39,0.06); }
    .upload-zone input[type="file"] {
      position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
    }
    .upload-icon  { font-size: 28px; margin-bottom: 8px; }
    .upload-label { font-size: 13px; color: #EF9F27; font-weight: 500; display: block; margin-bottom: 4px; }
    .upload-hint  { font-size: 11px; color: #888780; }
    .preview-img  { width: 100%; border-radius: 10px; margin-bottom: 12px; display: none; max-height: 220px; object-fit: cover; }
    .scan-btn {
      width: 100%; background: #EF9F27; color: #1a1208; border: none; border-radius: 10px;
      padding: 12px; font-size: 13px; font-weight: 500; cursor: pointer; display: none;
      letter-spacing: 0.5px; transition: opacity 0.15s; font-family: 'DM Sans', sans-serif; margin-top: 12px;
    }
    .scan-btn:hover    { opacity: 0.85; }
    .scan-btn:disabled { opacity: 0.6; cursor: not-allowed; }
 
    /* ── Result panel ── */
    .result-panel {
      background: rgba(255,255,255,0.05); border: 0.5px solid rgba(255,255,255,0.13);
      border-radius: 12px; padding: 16px; margin-top: 12px; display: none;
    }
    .result-verdict { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 300; margin-bottom: 6px; }
    .verdict-yes { color: #9FE1CB; }
    .verdict-no  { color: #F5C4B3; }
    .verdict-ok  { color: #FAC775; }
    .result-detail { font-size: 12px; color: #B4B2A9; line-height: 1.6; }
    .result-tags   { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
    .result-tag    { font-size: 10px; border-radius: 20px; padding: 3px 10px; letter-spacing: 0.5px; }
    .tag-good { background: #085041; color: #9FE1CB; }
    .tag-warn { background: #633806; color: #FAC775; }
    .tag-bad  { background: #791F1F; color: #F7C1C1; }
 
    /* ── Loading dots ── */
    .loading-dots { display: inline-flex; gap: 4px; margin-left: 6px; vertical-align: middle; }
    .loading-dots span { width: 4px; height: 4px; background: #1a1208; border-radius: 50%; animation: bounce 1.2s infinite; }
    .loading-dots span:nth-child(2) { animation-delay: 0.2s; }
    .loading-dots span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes bounce {
      0%, 80%, 100% { opacity: 0.3; transform: translateY(0); }
      40% { opacity: 1; transform: translateY(-3px); }
    }
 
    /* ── Nav bar ── */
    .nav-bar {
      background: #1a1208;
      display: flex;
      justify-content: space-around;
      padding: 10px 0 18px;
      border-top: 0.5px solid #333;
      position: sticky;
      bottom: 0;
      z-index: 10;
    }
    .nav-item {
      display: flex; flex-direction: column; align-items: center; gap: 3px;
      font-size: 9px; letter-spacing: 1px; text-transform: uppercase;
      color: #888780; cursor: pointer; padding: 2px 12px; transition: color 0.15s;
    }
    .nav-item.active { color: #EF9F27; }
    .nav-icon { font-size: 18px; line-height: 1; }
 
    /* ── API key notice ── */
    .api-notice {
      background: #FAEEDA; border: 0.5px solid #EF9F27; border-radius: 10px;
      padding: 12px 14px; margin: 0 20px 16px; font-size: 11px; color: #633806; line-height: 1.6;
    }
    .api-notice strong { display: block; margin-bottom: 4px; font-size: 10px; letter-spacing: 1px; text-transform: uppercase; }
    .api-key-input {
      width: 100%; margin-top: 8px; padding: 8px 10px;
      border: 0.5px solid #EF9F27; border-radius: 8px; background: white;
      font-size: 12px; font-family: monospace; color: #2C2C2A; outline: none;
    }
 
    /* ════════════════════════════════════════
       WEEK VIEW
    ════════════════════════════════════════ */
    .week-hero {
      background: linear-gradient(160deg, #1a1208 0%, #2c1f08 60%, #3b2a10 100%);
      padding: 28px 20px 24px;
    }
    .week-hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 30px; font-weight: 300; color: #FAF0D7; line-height: 1.1; margin-bottom: 4px;
    }
    .week-hero-sub { font-size: 11px; color: #888780; letter-spacing: 1.5px; text-transform: uppercase; }
 
    .week-list { padding: 16px 20px; display: flex; flex-direction: column; gap: 10px; }
    .week-card {
      background: white; border: 0.5px solid #D3D1C7; border-radius: 16px;
      padding: 14px 16px; display: flex; align-items: center; gap: 14px;
      cursor: pointer; transition: all 0.15s;
    }
    .week-card:hover { border-color: #EF9F27; background: #fffdf8; transform: translateX(2px); }
    .week-card.today { border-color: #EF9F27; background: #fffdf8; }
    .week-day-badge {
      width: 48px; height: 48px; border-radius: 14px;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      flex-shrink: 0; font-size: 9px; letter-spacing: 1px; text-transform: uppercase; font-weight: 500;
    }
    .week-day-num { font-size: 18px; font-weight: 500; line-height: 1; }
    .week-day-info { flex: 1; }
    .week-day-name { font-size: 14px; font-weight: 500; margin-bottom: 2px; }
    .week-day-planet { font-size: 11px; color: #888780; margin-bottom: 4px; font-style: italic; }
    .week-color-dots { display: flex; gap: 4px; }
    .week-dot { width: 10px; height: 10px; border-radius: 50%; }
    .week-badge-label { font-size: 9px; letter-spacing: 0.5px; margin-top: 2px; }
    .today-tag {
      background: rgba(239,159,39,0.15); color: #EF9F27;
      font-size: 9px; letter-spacing: 1px; text-transform: uppercase;
      padding: 3px 8px; border-radius: 10px; border: 0.5px solid rgba(239,159,39,0.4);
      flex-shrink: 0;
    }
 
    /* ════════════════════════════════════════
       VASTU VIEW
    ════════════════════════════════════════ */
    .vastu-hero {
      background: linear-gradient(160deg, #0c2a4a 0%, #1a3a5c 60%, #1e4570 100%);
      padding: 28px 20px 32px; position: relative; overflow: hidden;
    }
    .vastu-hero::before {
      content: ''; position: absolute; top: -20px; right: -20px;
      width: 160px; height: 160px;
      background: radial-gradient(circle, rgba(55,138,221,0.3) 0%, transparent 70%);
      border-radius: 50%;
    }
    .vastu-hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 32px; font-weight: 300; color: #E6F4FF; line-height: 1.1; margin-bottom: 6px;
    }
    .vastu-hero-sub { font-size: 11px; color: #7aaed4; letter-spacing: 1.5px; text-transform: uppercase; }
 
    .vastu-compass {
      margin: 20px 20px 0;
      background: white; border-radius: 20px; padding: 20px;
      border: 0.5px solid #D3D1C7;
    }
    .compass-title {
      font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: #888780; margin-bottom: 16px; text-align: center;
    }
    .compass-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px;
    }
    .compass-cell {
      border-radius: 12px; padding: 10px 8px; text-align: center; transition: transform 0.15s;
    }
    .compass-cell:hover { transform: scale(1.03); }
    .compass-cell.active { ring: 2px solid #EF9F27; }
    .compass-dir { font-size: 9px; letter-spacing: 1px; text-transform: uppercase; opacity: 0.6; margin-bottom: 4px; }
    .compass-zone { font-size: 11px; font-weight: 500; line-height: 1.3; margin-bottom: 3px; }
    .compass-element { font-size: 10px; opacity: 0.7; }
    .compass-center {
      background: #1a1208; color: #EF9F27; border-radius: 12px;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
    }
    .compass-center-symbol { font-size: 22px; line-height: 1; }
    .compass-center-label { font-size: 8px; letter-spacing: 1px; text-transform: uppercase; margin-top: 4px; opacity: 0.7; }
 
    .vastu-today-card {
      margin: 12px 20px 0;
      background: linear-gradient(135deg, #E6F1FB, #f0f7ff);
      border: 0.5px solid #378ADD; border-radius: 16px; padding: 16px;
    }
    .vastu-today-label { font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: #378ADD; margin-bottom: 8px; }
    .vastu-today-dir {
      font-family: 'Cormorant Garamond', serif;
      font-size: 26px; font-weight: 300; color: #0C447C; margin-bottom: 4px;
    }
    .vastu-today-desc { font-size: 12px; color: #1a4a7c; line-height: 1.6; }
 
    .vastu-rules { padding: 16px 20px; display: flex; flex-direction: column; gap: 10px; }
    .vastu-rule-card {
      background: white; border: 0.5px solid #D3D1C7; border-radius: 14px; padding: 14px 16px;
      display: flex; gap: 12px; align-items: flex-start;
    }
    .vastu-rule-icon {
      width: 36px; height: 36px; border-radius: 10px; background: #E6F1FB;
      display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0;
    }
    .vastu-rule-title { font-size: 13px; font-weight: 500; margin-bottom: 3px; }
    .vastu-rule-desc { font-size: 11px; color: #888780; line-height: 1.5; }
 
    /* ════════════════════════════════════════
       FENG SHUI VIEW
    ════════════════════════════════════════ */
    .feng-hero {
      background: linear-gradient(160deg, #0a2a10 0%, #1a4a1a 60%, #1e5a20 100%);
      padding: 28px 20px 32px; position: relative; overflow: hidden;
    }
    .feng-hero::before {
      content: ''; position: absolute; top: -20px; right: -20px;
      width: 160px; height: 160px;
      background: radial-gradient(circle, rgba(99,153,34,0.3) 0%, transparent 70%);
      border-radius: 50%;
    }
    .feng-hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 32px; font-weight: 300; color: #E6FFE8; line-height: 1.1; margin-bottom: 6px;
    }
    .feng-hero-sub { font-size: 11px; color: #7aad7a; letter-spacing: 1.5px; text-transform: uppercase; }
 
    .feng-bagua {
      margin: 20px 20px 0;
      background: white; border-radius: 20px; padding: 20px; border: 0.5px solid #D3D1C7;
    }
    .bagua-title { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: #888780; margin-bottom: 16px; text-align: center; }
    .bagua-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; }
    .bagua-cell {
      border-radius: 12px; padding: 10px 8px; text-align: center;
      transition: transform 0.15s; cursor: default;
    }
    .bagua-cell:hover { transform: scale(1.03); }
    .bagua-dir { font-size: 9px; letter-spacing: 1px; text-transform: uppercase; opacity: 0.6; margin-bottom: 3px; }
    .bagua-life { font-size: 11px; font-weight: 500; margin-bottom: 2px; }
    .bagua-element-tag { font-size: 10px; opacity: 0.7; }
    .bagua-center {
      background: #1a1208; color: #EF9F27; border-radius: 12px;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
    }
 
    .feng-elements { padding: 16px 20px; display: flex; flex-direction: column; gap: 10px; }
    .feng-element-card {
      border-radius: 16px; padding: 16px; position: relative; overflow: hidden;
    }
    .feng-el-header { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .feng-el-icon { font-size: 24px; }
    .feng-el-name { font-size: 15px; font-weight: 500; }
    .feng-el-season { font-size: 11px; opacity: 0.7; }
    .feng-el-desc { font-size: 12px; line-height: 1.6; opacity: 0.85; }
    .feng-el-qualities { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 8px; }
    .feng-el-tag { font-size: 10px; padding: 2px 8px; border-radius: 10px; background: rgba(255,255,255,0.2); }
    .feng-today-banner {
      margin: 12px 20px 0;
      background: linear-gradient(135deg, #EAF3DE, #f0f8e8);
      border: 0.5px solid #639922; border-radius: 16px; padding: 16px;
    }
    .feng-today-label { font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: #639922; margin-bottom: 8px; }
    .feng-today-element {
      font-family: 'Cormorant Garamond', serif;
      font-size: 26px; font-weight: 300; color: #27500A; margin-bottom: 4px;
    }
    .feng-today-desc { font-size: 12px; color: #2a5a0a; line-height: 1.6; }
  </style>
</head>
<body>
<div class="app">
 
  <!-- Top bar -->
  <div class="top-bar">
    <span class="day-label" id="currentDay">Saturday</span>
    <span class="app-name">Chi · Prana</span>
    <span class="element-badge" id="elementBadge">Wood + Ether</span>
  </div>
 
  <!-- ══════════ TODAY TAB ══════════ -->
  <div class="tab-view active" id="tab-today">
    <div class="hero">
      <div class="compass-ring"></div>
      <div class="compass-ring2"></div>
      <div style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:12px;letter-spacing:3px;color:#EF9F27;text-transform:uppercase;margin-bottom:8px;" id="planetLabel">Day of Jupiter</div>
      <div class="hero-title">Today's<br>sacred palette</div>
      <div class="hero-sub" id="dateLabel">April 25 · Vastu &amp; Feng Shui guide</div>
      <div class="element-row">
        <span class="element-chip active" id="chip1">Wood element</span>
        <span class="element-chip active" id="chip2">Ether / Akasha</span>
        <span class="element-chip" id="chip3">Jupiter governed</span>
      </div>
    </div>
 
    <div style="padding:16px 20px 4px;">
      <div class="vastu-strip">
