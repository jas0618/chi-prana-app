    {dir:'N',zone:'Wealth & Career',element:'Water',bg:'#e6f1fb',color:'#0c447c'},
    {dir:'NE',zone:'Wisdom & Divine',element:'Space',bg:'#eef5ff',color:'#1a2a5a'},
    {dir:'W',zone:'Creativity & Joy',element:'Earth',bg:'#faf0e0',color:'#5a3a10'},
    {dir:'',zone:'',element:'',bg:'',color:'',isCenter:true},
    {dir:'E',zone:'Health & Sun',element:'Fire',bg:'#fff0e0',color:'#7a3a10'},
    {dir:'SW',zone:'Relationships',element:'Earth',bg:'#faf0d8',color:'#5a3010'},
    {dir:'S',zone:'Fame & Success',element:'Fire',bg:'#fff0e8',color:'#7a2010'},
    {dir:'SE',zone:'Abundance & Fire',element:'Fire',bg:'#fff4e0',color:'#6a3010'},
  ];
 
  /* ── Ba-Gua data ── */
  const BAGUA = [
    {dir:'SE',life:'Wealth',element:'Wood',bg:'#1a3a1a',color:'#C0DD97'},
    {dir:'S',life:'Fame',element:'Fire',bg:'#5c1010',color:'#F5C4B3'},
    {dir:'SW',life:'Love',element:'Earth',bg:'#4a3a10',color:'#FAC775'},
    {dir:'E',life:'Family',element:'Wood',bg:'#1a3a1a',color:'#C0DD97'},
    {dir:'',life:'',element:'',bg:'',color:'',isCenter:true},
    {dir:'W',life:'Children',element:'Metal',bg:'#2a2a3a',color:'#D3D1C7'},
    {dir:'NE',life:'Knowledge',element:'Earth',bg:'#3a3a10',color:'#FAC775'},
    {dir:'N',life:'Career',element:'Water',bg:'#1a2a4a',color:'#B5D4F4'},
    {dir:'NW',life:'Helpers',element:'Metal',bg:'#2a2a3a',color:'#D3D1C7'},
  ];
 
  /* ─── TAB SWITCHER ─── */
  function switchTab(name, el) {
    document.querySelectorAll('.tab-view').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    el.classList.add('active');
  }
 
  /* ─── INIT ─── */
  function init() {
    const today = new Date();
    const dow = today.getDay();
    const data = DAY_DATA[dow];
    const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
 
    // Top bar
    document.getElementById('currentDay').textContent = data.name;
    document.getElementById('elementBadge').textContent = data.elementBadge;
 
    // Today tab
    document.getElementById('planetLabel').textContent = data.planet;
    document.getElementById('dateLabel').textContent = `${months[today.getMonth()]} ${today.getDate()} · Vastu & Feng Shui guide`;
    document.getElementById('chip1').textContent = data.elements[0];
    document.getElementById('chip2').textContent = data.elements[1];
    document.getElementById('chip3').textContent = data.elements[2];
    document.getElementById('vastuText').textContent = data.vastu;
    document.getElementById('fengText').textContent = data.feng;
 
    document.getElementById('colorGrid').innerHTML = data.colors.map(c => `
      <div class="color-card" style="background:${c.bg};color:${c.textColor};">
        <span class="power-tag">${c.power}</span>
        <div class="color-swatch" style="background:${c.swatch};"></div>
        <div class="color-name">${c.name}</div>
        <div class="color-reason">${c.reason}</div>
      </div>
    `).join('');
 
    document.getElementById('avoidText').innerHTML = `<strong style="color:#5F5E5A;">Avoid today:</strong> ${data.avoid}`;
 
    document.getElementById('activitiesList').innerHTML = data.activities.map(a => `
      <div class="activity-item">
        <div class="activity-icon ${a.iconBg}">${a.icon}</div>
        <div><div class="activity-name">${a.name}</div><div class="activity-desc">${a.desc}</div></div>
      </div>
    `).join('');
 
    // Week tab
    document.getElementById('weekSubLabel').textContent = `${months[today.getMonth()]} ${today.getFullYear()} · planetary overview`;
    const weekList = document.getElementById('weekList');
    const dayColors = ['#E8560A','#A8C8E8','#C0392B','#27AE60','#4A90D9','#E8A0B0','#2C3E50'];
    const dayBgs = ['#5c2a10','#1a2a4a','#5c1010','#1a3a1a','#1a3a5c','#4a1a2a','#1a1a2a'];
    weekList.innerHTML = Object.values(DAY_DATA).map((d, i) => {
      const isToday = i === dow;
      return `
        <div class="week-card ${isToday ? 'today' : ''}">
          <div class="week-day-badge" style="background:${dayBgs[i]};color:${d.colors[0].textColor};">
            <div class="week-day-num" style="color:${dayColors[i]};">${i===0?'Su':i===1?'M':i===2?'Tu':i===3?'W':i===4?'Th':i===5?'Fr':'Sa'}</div>
            <div class="week-badge-label" style="color:${dayColors[i]};opacity:0.7;">${d.elementBadge.split(' ')[0]}</div>
          </div>
          <div class="week-day-info">
            <div class="week-day-name">${d.name}</div>
            <div class="week-day-planet">${d.planet}</div>
            <div class="week-color-dots">
              ${d.colors.map(c => `<div class="week-dot" style="background:${c.swatch};"></div>`).join('')}
            </div>
          </div>
          ${isToday ? '<div class="today-tag">Today</div>' : ''}
        </div>
      `;
    }).join('');
 
    // Vastu tab
    document.getElementById('vastuTodayDir').textContent = data.vastuDir;
    document.getElementById('vastuTodayDesc').textContent = data.vastu;
    document.getElementById('vastuCompassGrid').innerHTML = VASTU_COMPASS.map(c => {
      if (c.isCenter) return `
        <div class="compass-cell compass-center">
          <div class="compass-center-symbol">🏠</div>
          <div class="compass-center-label">Brahma<br>Sthana</div>
        </div>`;
      const isActive = c.dir.includes(data.vastuDir.split('-').map(p=>p[0]).join('')) || data.vastuDir.includes(c.zone.split(' ')[0]);
      return `
        <div class="compass-cell" style="background:${c.bg};${isActive?'box-shadow:0 0 0 2px #378ADD;':''}">
          <div class="compass-dir">${c.dir}</div>
          <div class="compass-zone" style="color:${c.color};">${c.zone}</div>
          <div class="compass-element" style="color:${c.color};">${c.element}</div>
        </div>`;
    }).join('');
 
    // Feng Shui tab
    document.getElementById('fengTodayElement').textContent = data.fengElement;
    document.getElementById('fengTodayDesc').textContent = data.fengDesc;
    document.getElementById('baguaGrid').innerHTML = BAGUA.map(b => {
      if (b.isCenter) return `
        <div class="bagua-cell bagua-center">
          <div style="font-size:22px;">☯</div>
          <div style="font-size:8px;letter-spacing:1px;text-transform:uppercase;margin-top:4px;opacity:0.7;">Centre<br>Balance</div>
        </div>`;
      return `
        <div class="bagua-cell" style="background:${b.bg};color:${b.color};">
          <div class="bagua-dir">${b.dir}</div>
          <div class="bagua-life">${b.life}</div>
          <div class="bagua-element-tag">${b.element}</div>
        </div>`;
    }).join('');
  }
 
  /* ─── FILE UPLOAD ─── */
  function handleFile(event) {
    const file = event.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(e) {
      const img = document.getElementById('previewImg');
      img.src = e.target.result;
      img.style.display = 'block';
      document.getElementById('uploadPlaceholder').style.display = 'none';
      document.getElementById('scanBtn').style.display = 'block';
      document.getElementById('resultPanel').style.display = 'none';
    };
    reader.readAsDataURL(file);
  }
 
  /* ─── OUTFIT ANALYSER ─── */
  async function analyseOutfit() {
    const apiKey = document.getElementById('apiKeyInput').value.trim();
    if (!apiKey) { alert('Please enter your Anthropic API key above the scanner.'); return; }
 
    const btn = document.getElementById('scanBtn');
    const panel = document.getElementById('resultPanel');
    const imgEl = document.getElementById('previewImg');
 
    btn.innerHTML = 'Reading your energy <span class="loading-dots"><span></span><span></span><span></span></span>';
    btn.disabled = true;
    panel.style.display = 'none';
 
    const base64 = imgEl.src.split(',')[1];
    const mediaType = imgEl.src.split(';')[0].split(':')[1] || 'image/jpeg';
    const today = new Date();
    const dayNames = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
    const todayName = dayNames[today.getDay()];
    const data = DAY_DATA[today.getDay()];
    const goodColors = data.colors.map(c => c.name).join(', ');
 
    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method:'POST',
        headers:{'Content-Type':'application/json','x-api-key':apiKey,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},
        body:JSON.stringify({
          model:'claude-sonnet-4-20250514', max_tokens:1000,
          system:`You are a master of Vastu Shastra and Feng Shui with 30 years of practice. Today is ${todayName} — ${data.planet}. Auspicious colours for today are: ${goodColors}. Avoid: ${data.avoid}. Analyse the outfit in the image and give a warm, mystical but honest energy reading. Return ONLY valid JSON: {"verdict":"Auspicious","short_message":"Brief 5-7 word verdict","detail":"2-3 sentence detailed reading","tags":[{"label":"Short label","type":"good"}]} where verdict is Auspicious/Neutral/Inauspicious, tags 2-4 items with type good/warn/bad. Return ONLY the JSON, no markdown.`,
          messages:[{role:'user',content:[
            {type:'image',source:{type:'base64',media_type:mediaType,data:base64}},
            {type:'text',text:`Analyse this outfit for ${todayName} energy according to Vastu Shastra and Feng Shui.`}
          ]}]
        })
      });
      const json = await response.json();
      const raw = (json.content||[]).map(b=>b.text||'').join('');
      const result = JSON.parse(raw.replace(/```json|```/g,'').trim());
 
      const verdictClass = result.verdict==='Auspicious'?'verdict-yes':result.verdict==='Neutral'?'verdict-ok':'verdict-no';
      const icon = result.verdict==='Auspicious'?'✦ ':result.verdict==='Neutral'?'◈ ':'✧ ';
      const verdictEl = document.getElementById('resultVerdict');
      verdictEl.className = 'result-verdict '+verdictClass;
      verdictEl.textContent = icon+result.verdict+' — '+result.short_message;
      document.getElementById('resultDetail').textContent = result.detail;
      document.getElementById('resultTags').innerHTML = (result.tags||[]).map(t =>
        `<span class="result-tag ${t.type==='good'?'tag-good':t.type==='warn'?'tag-warn':'tag-bad'}">${t.label}</span>`
      ).join('');
      panel.style.display = 'block';
    } catch(err) {
      const verdictEl = document.getElementById('resultVerdict');
      verdictEl.className = 'result-verdict verdict-ok';
      verdictEl.textContent = '◈ Could not read energy';
      document.getElementById('resultDetail').textContent = 'Please check your API key and try again.';
      document.getElementById('resultTags').innerHTML = '';
      panel.style.display = 'block';
    }
    btn.innerHTML = 'Read the energy';
    btn.disabled = false;
  }
 
  init();
</script>
</body>
</html>
 
